<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body class="page page--<%= pageClass %>">
<%- include('../partials/header') %>
<main id="main" class="main">

  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow reveal" data-reveal>Compare</p>
      <h1 class="page-hero__title reveal" data-reveal>Three distinct products</h1>
      <p class="page-hero__lead reveal" data-reveal>Use this view to understand scope and boundaries—not to “pick a SKU.” None of these titles are offered for sale or download today; the comparison is here so the architecture reads clearly.</p>
    </div>
  </section>

  <section class="section">
    <div class="container compare-table-wrap reveal" data-reveal>
      <table class="compare-table">
        <thead>
          <tr>
            <th scope="col"></th>
            <th scope="col">CFO</th>
            <th scope="col">Eden</th>
            <th scope="col">Ledger</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">Core job</th>
            <td>Financial operating system: budgeting, planning, forecasting, cash flow, structured money intelligence</td>
            <td>Research aggregation, analysis, prioritization, and source evaluation with citations</td>
            <td>Encrypted identity vault and deterministic document prefilling</td>
          </tr>
          <tr>
            <th scope="row">Typical inputs</th>
            <td>Accounts, plans, OCR’d documents, optional Plaid—financial data only</td>
            <td>Recordings, video, articles, images, screenshots, public or user-provided material</td>
            <td>Identity fields, history, relationships, documents, up to two people (e.g. spouses)</td>
          </tr>
          <tr>
            <th scope="row"><%= SITE.steward.name %></th>
            <td>Interprets finances, surfaces patterns and risks, projections and runway from recorded data—deterministic</td>
            <td>Prioritizes facts to your context; scores sources on consistency, evidence, agreement, relevance</td>
            <td>Helps parse documents and map fields; never generates or guesses field values</td>
          </tr>
          <tr>
            <th scope="row">Explicitly not</th>
            <td>A research tool, generic life tracker, or open-ended “AI chat for money”</td>
            <td>A CFO mode, paper writer, paywall bypass, or judge of people</td>
            <td>A finance app, research notebook, or autofill that infers missing answers</td>
          </tr>
          <tr>
            <th scope="row">Availability</th>
            <td colspan="3"><%= SITE.availability.line %></td>
          </tr>
        </tbody>
      </table>
      <div class="compare-actions">
        <a href="product-cfo.html" class="btn btn--ghost">CFO</a>
        <a href="product-eden.html" class="btn btn--ghost">Eden</a>
        <a href="product-ledger.html" class="btn btn--ghost">Ledger</a>
        <span class="btn btn--ghost" style="cursor: default; opacity: 0.85;" role="status"><%= SITE.availability.ctaLabel %></span>
      </div>
    </div>
  </section>

</main>
<%- include('../partials/footer') %>
<%- include('../partials/mobile-nav') %>
<script type="module" src="/src/main.js"></script>
</body>
</html>
