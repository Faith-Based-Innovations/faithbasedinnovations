<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body class="page page--<%= pageClass %>">
<%- include('../partials/header') %>
<main id="main" class="main">

  <section class="hero-cine" data-parallax="slow">
    <div class="hero-cine__glow" aria-hidden="true"></div>
    <div class="container hero-cine__layout">
      <div class="hero-cine__copy">
        <p class="eyebrow reveal" data-reveal><%= SITE.legalName %></p>
        <h1 class="hero-cine__title reveal" data-reveal><%= SITE.hero.titleLine %><br /><span class="hero-cine__accent"><%= SITE.hero.titleAccent %></span></h1>
        <p class="hero-cine__lead reveal" data-reveal><%= SITE.hero.lead %></p>
        <div class="hero-cine__actions reveal" data-reveal>
          <a href="products.html" class="btn btn--primary btn--glow">View products</a>
          <a href="compare.html" class="btn btn--ghost">Compare</a>
        </div>
      </div>
      <div class="hero-cine__visual reveal" data-reveal data-reveal-delay="1">
        <div class="hero-cine__orb" aria-hidden="true">
          <% if (typeof heroOrbSrc !== 'undefined' && heroOrbSrc) { %>
          <img class="hero-cine__orb-img" src="<%= heroOrbSrc %>" alt="" decoding="async" />
          <% } %>
        </div>
        <div class="hero-cine__stack">
          <span class="hero-cine__chip">CFO</span>
          <span class="hero-cine__chip">Eden</span>
          <span class="hero-cine__chip">Ledger</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="split-pitch reveal" data-reveal>
        <div>
          <h2 class="section-title">Three products, one standard</h2>
          <p class="section-lead">CFO, Eden, and Ledger are independent titles with distinct missions. They share a premium desktop craft ethic and the same underlying intelligence layer—without blending finance, research, and identity into one confused surface.</p>
        </div>
        <ul class="pill-list">
          <li>Local-first architecture</li>
          <li>Privacy-first by design</li>
          <li><%= SITE.steward.name %>—rules-based, logic-driven intelligence</li>
          <li>Unified visual language, separate purposes</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--dark reveal" data-reveal>
    <div class="container narrow">
      <p class="eyebrow" style="text-align: center; margin-bottom: 0.75rem;"><%= SITE.steward.name %></p>
      <blockquote class="pull-quote">
        <p><%= SITE.steward.short %></p>
        <footer>— <%= SITE.brand %></footer>
      </blockquote>
      <p class="scene__center" style="margin-top: 1.5rem;"><%= SITE.steward.homeBlurb %></p>
    </div>
  </section>

  <section class="section section--products">
    <div class="container">
      <header class="section-head reveal" data-reveal>
        <p class="eyebrow">The line-up</p>
        <h2 class="section-title"><%= SITE.suiteSectionTitle %></h2>
        <p class="section-lead" style="max-width: 52ch; margin-top: 0.75rem;">Each product has its own page, narrative, and scope. CFO is the flagship; Eden and Ledger are equally intentional—built as real software, not placeholders.</p>
      </header>
      <div class="product-trio">
        <% NAV_PRODUCTS.forEach(function (p, i) { %>
          <article class="product-card reveal" data-reveal data-reveal-delay="<%= i %>">
            <a href="<%= p.href %>" class="product-card__link">
              <span class="product-card__status"><%= SITE.availability.badge %></span>
              <span class="product-card__tag"><%= PRODUCTS[p.id].tag %></span>
              <h3 class="product-card__name"><%= p.label %></h3>
              <p class="product-card__line"><%= p.line %></p>
              <span class="product-card__cta">Read the product page</span>
            </a>
          </article>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="section section--dark reveal" data-reveal>
    <div class="container narrow">
      <blockquote class="pull-quote">
        <p>Software that stays on your machine, under your control—with intelligence framed as discipline, not hype.</p>
        <footer>— <%= SITE.brand %></footer>
      </blockquote>
    </div>
  </section>

  <section class="section">
    <div class="container cta-band reveal" data-reveal>
      <div>
        <h2 class="section-title">See how they differ</h2>
        <p class="section-lead">A concise comparison of focus, Steward’s role, and boundaries—no checkout, no funnel.</p>
      </div>
      <a href="compare.html" class="btn btn--primary btn--glow">Open comparison</a>
    </div>
  </section>

  <%- include('../partials/availability-status') %>

</main>
<%- include('../partials/footer') %>
<%- include('../partials/mobile-nav') %>
<script type="module" src="/src/main.js"></script>
</body>
</html>
