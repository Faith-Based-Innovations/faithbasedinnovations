<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body class="page page--<%= pageClass %>">
<%- include('../partials/header') %>
<main id="main" class="main">

  <section class="page-hero">
    <div class="container">
      <p class="eyebrow reveal" data-reveal>Support</p>
      <h1 class="page-hero__title reveal" data-reveal>Help, documentation, and policies</h1>
      <p class="page-hero__lead reveal" data-reveal>Everything here uses the same brand system as the rest of the site—clear, direct, and easy to navigate.</p>
    </div>
  </section>

  <section class="section">
    <div class="container support-grid">
      <a href="security.html" class="support-card reveal" data-reveal>
        <h2 class="support-card__title">Security</h2>
        <p>How we think about access, encryption, and infrastructure.</p>
      </a>
      <a href="privacy.html" class="support-card reveal" data-reveal>
        <h2 class="support-card__title">Privacy</h2>
        <p>What we collect, what we avoid, and where data lives.</p>
      </a>
      <a href="terms.html" class="support-card reveal" data-reveal>
        <h2 class="support-card__title">Terms</h2>
        <p>Baseline terms for using our site and products.</p>
      </a>
      <div class="support-card support-card--muted reveal" data-reveal>
        <h2 class="support-card__title">Documentation</h2>
        <p>Product documentation will be published here alongside each product.</p>
      </div>
      <div class="support-card support-card--muted reveal" data-reveal>
        <h2 class="support-card__title">Hardship</h2>
        <p>Products are not offered today. When anything is made available in the future, accommodations and contact paths will be described in policy updates—not via marketing forms on this site.</p>
      </div>
    </div>
  </section>

</main>
<%- include('../partials/footer') %>
<%- include('../partials/mobile-nav') %>
<script type="module" src="/src/main.js"></script>
</body>
</html>
