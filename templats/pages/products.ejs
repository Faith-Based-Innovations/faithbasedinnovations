<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body class="page page--<%= pageClass %>">
<%- include('../partials/header') %>
<main id="main" class="main">

  <section class="page-hero">
    <div class="container">
      <p class="eyebrow reveal" data-reveal>Products</p>
      <h1 class="page-hero__title reveal" data-reveal>CFO, Eden, and Ledger</h1>
      <p class="page-hero__lead reveal" data-reveal>Three standalone premium applications. Same parent company, same bar for craft, same <%= SITE.steward.name %> layer—each product answers a different problem without borrowing the others’ identity.</p>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container narrow reveal" data-reveal>
      <h2 class="section-title" style="font-size: clamp(1.35rem, 2.5vw, 1.85rem);"><%= SITE.steward.name %></h2>
      <p class="section-lead" style="margin-top: 0.5rem;"><%= SITE.steward.short %></p>
    </div>
  </section>

  <section class="section">
    <div class="container product-trio product-trio--large">
      <% NAV_PRODUCTS.forEach(function (p, i) { %>
        <article class="product-spotlight reveal" data-reveal data-reveal-delay="<%= i %>">
          <div class="product-spotlight__inner">
            <span class="product-spotlight__tag"><%= PRODUCTS[p.id].tag %></span>
            <p class="product-card__status" style="margin-bottom: 0.35rem;"><%= SITE.availability.badge %></p>
            <h2 class="product-spotlight__name"><%= p.label %></h2>
            <p class="product-spotlight__headline"><%= PRODUCTS[p.id].headline %></p>
            <p class="product-spotlight__copy"><%= PRODUCTS[p.id].subhead %></p>
            <a href="<%= p.href %>" class="btn btn--primary">Product page</a>
          </div>
        </article>
      <% }); %>
    </div>
  </section>

  <section class="section section--band reveal" data-reveal>
    <div class="container cta-band">
      <div>
        <h2 class="section-title">Compare at a glance</h2>
        <p class="section-lead">Focus, Steward’s role, and what each product refuses to do.</p>
      </div>
      <a href="compare.html" class="btn btn--ghost">Open comparison</a>
    </div>
  </section>

  <%- include('../partials/availability-status') %>

</main>
<%- include('../partials/footer') %>
<%- include('../partials/mobile-nav') %>
<script type="module" src="/src/main.js"></script>
</body>
</html>
